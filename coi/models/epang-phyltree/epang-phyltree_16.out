            best_prob[rank2] = 0
            best_taxon[rank2] = "NA"
            new_prob[rank2] = $5
          }
        }
      }
      END{
        write_record(best_prob, best_taxon, new_prob)
      }' train_aa_16/testshort/per_query_testshort_aa_16.tsv
